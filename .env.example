# Copy this file to ".env" and fill in the real values.
# The .env file should NOT be committed to git.

# --- Database connection ---
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432
DB_NAME=DB1

# --- JWT settings ---
# A long random string. Used to sign the login tokens.
# You can generate one by running in Python: import secrets; print(secrets.token_hex(32))
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
# How long a login lasts, in minutes
JWT_EXPIRE_MINUTES=60

# --- Frontend URL (for CORS) ---
# This is where the React app runs in development
FRONTEND_URL=http://localhost:5173
